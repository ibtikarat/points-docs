{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Points",
  "description": "Points API - Saudi Arabia's unified loyalty rewards platform",
  "seo": {
    "metatags": {
      "title": "Points API Documentation",
